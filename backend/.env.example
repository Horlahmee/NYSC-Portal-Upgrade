# App
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://nysc_user:nysc_pass@localhost:5432/nysc_db

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=super-secret-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=super-refresh-secret-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# Remita
REMITA_BASE_URL=https://remitademo.net/remita/exapp/api/v1/send/api
REMITA_MERCHANT_ID=your-merchant-id
REMITA_SERVICE_TYPE_ID=your-service-type-id
REMITA_API_KEY=your-api-key

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Email (Resend)
RESEND_API_KEY=re_your-api-key
EMAIL_FROM=noreply@nysc.gov.ng

# SMS (Termii)
TERMII_API_KEY=your-termii-key
TERMII_SENDER_ID=NYSC
